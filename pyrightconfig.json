{
  "include": ["app", "tests"],
  "exclude": ["**/node_modules", "**/__pycache__", ".venv", "venv"],
  "extraPaths": ["./"],
  "typeCheckingMode": "standard",
  "diagnosticSeverityOverrides": {
    "reportConstantRedefinition": "warning",
    "reportInvalidTypeVarUse": "warning",
    "reportMissingImports": "error",
    "reportMissingModuleSource": "warning",
    "reportMissingTypeStubs": "warning",
    "reportOptionalArgument": "warning",
    "reportOptionalIterable": "warning",
    "reportOptionalMemberAccess": "warning",
    "reportOptionalOperand": "warning",
    "reportOptionalSubscript": "warning",
    "reportOptionalCall": "warning",
    "reportOptionalContextManager": "warning",
    "reportOptionalIsInstance": "warning",
    "reportOptionalUnpack": "warning",
    "reportOptionalGeneralTypeIssues": "warning",
    "reportOptionalSequenceMemberAccess": "warning",
    "reportOptionalMapping": "warning",
    "reportOptionalFunctionCall": "warning",
    "reportOptionalVariableAccess": "warning",
    "reportOptionalParameterAssignment": "warning",
    "reportOptionalReturnValue": "warning",
    "reportOptionalSuperCall": "warning",
    "reportOptionalSubscriptAccess": "warning",
    "reportOptionalAssignment": "warning",
    "reportOptionalIndexing": "warning",
    "reportOptionalSlicing": "warning",
    "reportOptionalComparisonOperation": "warning",
    "reportOptionalArithmeticOperation": "warning",
    "reportOptionalBooleanOperation": "warning",
    "reportOptionalContextManagerEntry": "warning",
    "reportOptionalContextManagerExit": "warning",
    "reportOptionalAsyncContextManagerEntry": "warning",
    "reportOptionalAsyncContextManagerExit": "warning",
    "reportOptionalAsyncIterable": "warning",
    "reportOptionalAsyncIterator": "warning",
    "reportOptionalAsyncNext": "warning",
    "reportOptionalAsyncSend": "warning",
    "reportOptionalAsyncThrow": "warning",
    "reportOptionalAsyncClose": "warning",
    "reportUnusedClass": "warning",
    "reportUnusedFunction": "warning",
    "reportUnusedVariable": "warning",
    "reportDuplicateImport": "warning",
    "reportUnusedImport": "warning",
    "reportUnusedCallResult": "warning",
    "reportUnusedExpression": "warning",
    "reportUnnecessaryIsInstance": "warning",
    "reportUnnecessaryCast": "warning",
    "reportUnnecessaryComparison": "warning",
    "reportUnnecessaryContains": "warning",
    "reportAssignmentType": "warning",
    "reportAttributeAccessIssue": "warning",
    "reportCallIssue": "warning",
    "reportIndexIssue": "warning",
    "reportIncompatibleMethodOverride": "warning",
    "reportIncompatibleVariableOverride": "warning",
    "reportInconsistentConstructor": "warning",
    "reportInconsistentTreatmentOfForLoopBreaks": "warning",
    "reportInconsistentTreatmentOfIfElseReturn": "warning",
    "reportInconsistentTreatmentOfWhileLoopBreaks": "warning",
    "reportInvalidStringEscapeSequence": "warning",
    "reportInvalidTypeForm": "warning",
    "reportInvalidTypeVarUse": "warning",
    "reportMatchNotExhaustive": "warning",
    "reportMissingParameterType": "warning",
    "reportMissingReturnType": "warning",
    "reportMissingTypeArgument": "warning",
    "reportPrivateImportUsage": "warning",
    "reportPrivateUsage": "warning",
    "reportReturnType": "warning",
    "reportTypeCommentUsage": "warning",
    "reportTypedDictNotRequiredAccess": "warning",
    "reportUnboundVariable": "warning",
    "reportUndefinedVariable": "warning",
    "reportUnknownArgumentType": "warning",
    "reportUnknownLambdaType": "warning",
    "reportUnknownMemberType": "warning",
    "reportUnknownParameterType": "warning",
    "reportUnknownVariableType": "warning",
    "reportUnsupportedDunderAll": "warning",
    "reportUnsupportedRuntimeVersion": "warning",
    "reportUnsupportedTypingExtension": "warning",
    "reportUntypedBaseClass": "warning",
    "reportUntypedClassDecorator": "warning",
    "reportUntypedFunctionDecorator": "warning",
    "reportUntypedNamedTuple": "warning",
    "reportConstantRedefinition": "warning",
    "reportInvalidTypeVarUse": "warning",
    "reportSelfClsParameterName": "none",
    "reportAssertAlwaysTrue": "none",
    "reportSyntaxError": "error"
  }
}
